[Unit]
Description=Fittin Cloudflare Tunnel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/cloudflared --config %h/.cloudflared/config.yml tunnel run
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
